{
  "name": "aags",
  "private": true,
  "version": "1.2.1",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "AAGS",
  "description": "Apex Adaptive Grid System - 自适应波动率三层网格量化交易系统",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:engine": "node build-engine.mjs",
    "build": "tsc -b && vite build && node build-engine.mjs",
    "build:exe": "tsc -b && vite build && node build-engine.mjs && electron-builder --win",
    "build:mac": "tsc -b && vite build && node build-engine.mjs && electron-builder --mac",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.aags.grid-trading",
    "productName": "AAGS",
    "copyright": "Copyright © 2026 AAGS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server.cjs",
      "dist-engine/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "server.cjs",
      "package.json",
      "dist/**/*",
      "dist-engine/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/ws/**/*",
      "node_modules/crypto-js/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "artifactName": "AAGS-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "public/icon-512.png",
      "category": "public.app-category.finance",
      "artifactName": "AAGS-${version}-mac.${ext}"
    },
    "dmg": {
      "title": "AAGS ${version}",
      "icon": "public/icon-512.png",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Yeedy985",
        "repo": "AAGSReleases"
      }
    ],
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AAGS"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@tailwindcss/vite": "^4.2.1",
    "app-builder-lib": "^26.8.1",
    "autoprefixer": "^10.4.27",
    "better-sqlite3": "^12.8.0",
    "crypto-js": "^4.2.0",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "docx": "^9.6.1",
    "electron-updater": "^6.8.3",
    "file-saver": "^2.0.5",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "tailwindcss": "^4.2.1",
    "vite-plugin-pwa": "^1.2.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/crypto-js": "^4.2.2",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.59.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
